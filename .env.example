# LibraryNexus environment variables
# Copy to .env for local development. Configure the same values in Render for production.

# Runtime
NODE_ENV=development
PORT=5000

# Backend API
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/library_lms?retryWrites=true&w=majority
JWT_SECRET=<generate-a-long-random-access-token-secret>
JWT_REFRESH_SECRET=<generate-a-different-long-random-refresh-token-secret>
CLIENT_URL=http://localhost:5173

# Initial Super Admin
SUPER_ADMIN_EMAIL=<super-admin-email>
SUPER_ADMIN_PASSWORD=<super-admin-password>

# Cloudinary
CLOUDINARY_CLOUD_NAME=<cloudinary-cloud-name>
CLOUDINARY_API_KEY=<cloudinary-api-key>
CLOUDINARY_API_SECRET=<cloudinary-api-secret>

# Frontend
VITE_API_URL=http://localhost:5000
VITE_APP_URL=http://localhost:5173

# Optional
LOG_LEVEL=info
RATE_LIMIT_MAX=300
AUTH_RATE_LIMIT_MAX=20
